{
  "info": {
    "_postman_id": "3d2eac44-bb2a-4f8f-8b1b-phase4rest01",
    "name": "Bitcoin Core REST",
    "description": "Phase 4 Bitcoin Core REST collection. JSON-only, read-only endpoints for local regtest. Requires bitcoind -rest=1 and uses the same HTTP port as JSON-RPC.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Blockchain",
      "description": "Read-only REST endpoints for chain state. JSON format only.",
      "item": [
        {
          "name": "chaininfo",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{protocol}}://{{host}}:{{rpc_port}}/rest/chaininfo.json",
              "protocol": "{{protocol}}",
              "host": [
                "{{host}}"
              ],
              "port": "{{rpc_port}}",
              "path": [
                "rest",
                "chaininfo.json"
              ]
            },
            "description": "Returns blockchain processing state. Mirrors getblockchaininfo. Requires -rest=1."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "  pm.expect(function () { pm.response.json(); }).not.to.throw();",
                  "});"
                ]
              }
            }
          ]
        },
        {
