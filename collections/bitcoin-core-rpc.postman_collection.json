  "item": [
    {
      "name": "Control",
      "description": "Control read-only RPC calls.",
      "item": [
        {
          "name": "getrpcinfo",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{rpc_user}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{rpc_password}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"1.0\",\n  \"id\": \"{{request_id}}\",\n  \"method\": \"getrpcinfo\",\n  \"params\": []\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{rpc_port}}/",
              "protocol": "{{protocol}}",
              "host": [
                "{{host}}"
              ],
              "port": "{{rpc_port}}",
              "path": [
                ""
              ]
            },
            "description": "Read-only Bitcoin Core JSON-RPC call: `getrpcinfo`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON-RPC shaped', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.satisfy((body) => Object.prototype.hasOwnProperty.call(body, 'result') || Object.prototype.hasOwnProperty.call(body, 'error'));",
                  "});"
                ]
              }
            }
          ]
        },
