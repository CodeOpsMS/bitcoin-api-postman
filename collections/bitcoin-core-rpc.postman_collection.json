              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"1.0\",\n  \"id\": \"{{request_id}}\",\n  \"method\": \"getrpcinfo\",\n  \"params\": []\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{rpc_port}}/",
              "protocol": "{{protocol}}",
              "host": [
                "{{host}}"
              ],
              "port": "{{rpc_port}}",
              "path": [
                ""
              ]
            },
            "description": "Read-only Bitcoin Core JSON-RPC call: `getrpcinfo`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "pm.test('Response is successful JSON-RPC', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.be.an('object');",
                  "  pm.expect(json).to.have.property('id', pm.environment.get('request_id'));",
                  "  pm.expect(json).to.have.property('error');",
                  "  pm.expect(json.error).to.eql(null);",
                  "  pm.expect(json).to.have.property('result');",
                  "});"
                ]
              }
            }
          ]
        },
